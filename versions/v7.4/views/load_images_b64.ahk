Refresh_Picture_GUI() {
	GLOBAL
	Gui, Main:Default
	iniFile := A_WorkingDir "\Config.ini"
	section := "Base64"
	IniRead, keys, %iniFile%, %section%
	if (keys != "ERROR" && keys != "") {
		Loop, Parse, keys, `n
		{
			IniConfig := StrSplit(A_LoopField,"=")
			key := IniConfig[1]
			value := IniConfig[2]
			PNG[key] := BitmapFromBase64(1,0,value)
			Picture_Bitmap := BitmapFromBase64(0,1,value)
			GuiControl,, Picture_%key%, % "HBITMAP:* " Picture_Bitmap


		}
	}
}